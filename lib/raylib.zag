pub fn set_save_file_data_callback(callback: SaveFileDataCallback) void -> SetSaveFileDataCallback(callback)
pub fn set_load_file_text_callback(callback: LoadFileTextCallback) void -> SetLoadFileTextCallback(callback)
pub fn set_save_file_text_callback(callback: SaveFileTextCallback) void -> SetSaveFileTextCallback(callback)
pub fn load_file_data(file_name: []u8, data_size: &mut i32) []mut u8 {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    
    let mut slice: []mut u8 = undefined;
    slice.ptr = cast<&mut u8>(LoadFileData(file_name_cstr, cast<&mut c_int>(data_size)));
    slice.len = cast<usize>(data_size.*);
    return slice;
}
pub fn unload_file_data(data: &mut u8) void -> UnloadFileData(cast<&mut c_uchar>(data))
pub fn save_file_data(file_name: []u8, data: &mut void, bytes_to_write: u32) bool {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    return SaveFileData(file_name_cstr, data, bytes_to_write);
}
pub fn load_file_text(file_name: []u8) []u8 {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    
    let result_cstr = LoadFileText(file_name_cstr);
    if (result_cstr == c_null) return "";

    let result_slice = std.sentinel_to_slice<c_char>(result_cstr, 0);
    UnloadFileText(result_cstr);

    return cast<[]u8>(result_slice);
}
// pub fn unload_file_text(text: &mut c_char) void -> UnloadFileText(text)
pub fn save_file_text(file_name: []u8, text: []u8) bool {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);

    let text_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_cstr);

    return SaveFileText(file_name_cstr, text_cstr);
}
