pub fn check_collision_lines(startPos1, endPos1, startPos2, endPos2: Vector2) ?Vector2 {
    let mut collision_point: Vector2 = undefined;
    return if (CheckCollisionLines(startPos1, endPos1, startPos2, endPos2, &mut collision_point))
        collision_point
    else nil;
}
