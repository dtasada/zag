pub fn get_font_default() Font -> GetFontDefault()
pub fn load_font(file_name: []u8) Font {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    return LoadFont(cast<&mut c_char>(file_name_cstr));
}
pub fn load_font_ex(file_name: []u8, font_size: i32, codepoints: ?[]i32) Font {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);

    let cp = if (codepoints) |cp| cast<&mut c_int>(cp.ptr) else c_null;
    let count = if (codepoints) |cp| cp.len else 0;

    return LoadFontEx(cast<&mut c_char>(file_name_cstr), font_size, cp, count);
}
pub fn load_font_from_image(image: Image, key: Color, firstChar: i32) Font -> LoadFontFromImage(image, key, firstChar)
pub fn load_font_from_memory(file_type: []u8, fileData: []u8, fontSize: i32, codepoints: []i32) Font {
    let file_type_cstr = std.to_cstr(file_type);
    defer std.free<c_char>(file_type_cstr);

    return LoadFontFromMemory(file_type_cstr, cast<&c_uchar>(fileData.ptr), fileData.len, fontSize, cast<&mut c_int>(codepoints.ptr), codepoints.len);
}
pub fn load_font_data(file_data: []u8, fontSize: i32, codepoints: []i32, type: FontType) &mut GlyphInfo {
    return LoadFontData(cast<&c_uchar>(file_data.ptr), file_data.len, fontSize, cast<&mut c_int>(codepoints.ptr), codepoints.len, cast<c_int>(type));
}
