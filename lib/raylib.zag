    defer std.free<c_char>(vs_code_cstr);

    let fs_code_cstr = std.to_cstr(fs_code);
    defer std.free<c_char>(fs_code_cstr);

    return LoadShaderFromMemory(cast<&mut c_char>(vs_code_cstr), cast<&mut c_char>(fs_code_cstr));
}
