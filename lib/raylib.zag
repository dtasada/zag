pub fn load_shader(vs_file_name, fs_file_name: []u8) Shader {
    let vs_file_name_cstr = std.to_cstr(vs_file_name);
    defer std.free<c_char>(vs_file_name_cstr);

    let fs_file_name_cstr = std.to_cstr(fs_file_name);
    defer std.free<c_char>(fs_file_name_cstr);

    return LoadShader(cast<&mut c_char>(vs_file_name_cstr), cast<&mut c_char>(fs_file_name_cstr));
}
