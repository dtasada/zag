bind fn SaveFileData(fileName: &c_char, data: &mut void, dataSize: c_int) bool; // Save data to file from byte array (write), returns true on success
bind fn ExportDataAsCode(data: &c_uchar, dataSize: c_int, fileName: &c_char) bool; // Export data to code (.h), returns true on success
bind fn LoadFileText(fileName: &c_char) &mut c_char;                     // Load text data from file (read), returns a '\0' terminated string
bind fn UnloadFileText(text: &mut c_char) void;                              // Unload file text data allocated by LoadFileText()
bind fn SaveFileText(fileName, text: &c_char) bool;    // Save text data to file (write), string must be '\0' terminated, returns true on success

// File access custom callbacks
// WARNING: Callbacks setup is intended for advanced users
