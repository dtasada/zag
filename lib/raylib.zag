bind fn SetSaveFileDataCallback(callback: SaveFileDataCallback) void;  // Set custom file binary data saver
bind fn SetLoadFileTextCallback(callback: LoadFileTextCallback) void;  // Set custom file text data loader
bind fn SetSaveFileTextCallback(callback: SaveFileTextCallback) void;  // Set custom file text data saver

//------------------------------------------------------------------------------------
// Files management functions (Module: core)
//------------------------------------------------------------------------------------
bind fn FileRename(fileName, fileRename: &c_char) c_int; // Rename file (if exists)
bind fn FileRemove(fileName: &mut c_char) c_int;                         // Remove file (if exists)
bind fn FileCopy(srcPath, dstPath: &mut c_char) c_int;       // Copy file from one path to another, dstPath created if it doesn't exist
bind fn FileMove(srcPath, dstPath: &mut c_char) c_int;       // Move file from one directory to another, dstPath created if it doesn't exist
bind fn FileTextReplace(fileName, search, replacement: &mut c_char) c_int; // Replace text in an existing file
bind fn FileTextFindIndex(fileName, search: &mut c_char) c_int; // Find text in existing file
bind fn FileExists(fileName: &mut c_char) bool;                        // Check if file exists
bind fn DirectoryExists(dirPath: &mut c_char) bool;                    // Check if a directory path exists
bind fn IsFileExtension(fileName, ext: &mut c_char) bool;  // Check file extension (recommended include point: .png, .wav)
bind fn GetFileLength(fileName: &mut c_char) c_int;                      // Get file length in bytes (NOTE: GetFileSize() conflicts with windows.h)
bind fn GetFileModTime(fileName: &mut c_char) c_long;                    // Get file modification time (last write time)
bind fn GetFileExtension(fileName: &mut c_char) &mut c_char;           // Get pointer to extension for a filename string (includes dot: '.png')
bind fn GetFileName(filePath: &mut c_char) &mut c_char;                // Get pointer to filename for a path string
bind fn GetFileNameWithoutExt(filePath: &mut c_char) &mut c_char;      // Get filename string without extension (uses static string)
bind fn GetDirectoryPath(filePath: &mut c_char) &mut c_char;           // Get full path for a given fileName with path (uses static string)
bind fn GetPrevDirectoryPath(dirPath: &mut c_char) &mut c_char;        // Get previous directory path for a given path (uses static string)
bind fn GetWorkingDirectory() &mut c_char;                        // Get current working directory (uses static string)
bind fn GetApplicationDirectory() &mut c_char;                    // Get the directory of the running application (uses static string)
bind fn MakeDirectory(dirPath: &mut c_char) c_int;                       // Create directories (including full path requested), returns 0 on success
bind fn ChangeDirectory(dirPath: &mut c_char) bool;                    // Change working directory, return true on success
bind fn IsPathFile(path: &mut c_char) bool;                            // Check if a given path is a file or a directory
bind fn IsFileNameValid(fileName: &mut c_char) bool;                   // Check if fileName is valid for the platform/OS
bind fn LoadDirectoryFiles(dirPath: &mut c_char) FilePathList;         // Load directory filepaths
bind fn LoadDirectoryFilesEx(basePath, filter: &mut c_char, scanSubdirs: bool) FilePathList; // Load directory filepaths with extension filtering and recursive directory scan. Use 'DIR' in the filter string to include directories in the result
bind fn UnloadDirectoryFiles(files: FilePathList) void;                // Unload filepaths
bind fn IsFileDropped() bool;                                     // Check if a file has been dropped into window
bind fn LoadDroppedFiles() FilePathList;                          // Load dropped filepaths
bind fn UnloadDroppedFiles(files: FilePathList) void;                  // Unload dropped filepaths
bind fn GetDirectoryFileCount(dirPath: &mut c_char) c_uint;      // Get the file count in a directory
bind fn GetDirectoryFileCountEx(basePath, filter: &mut c_char, scanSubdirs: bool) c_uint;// Get the file count in a directory with extension filtering and recursive directory scan. Use 'DIR' in the filter string to include directories in the result

// Compression/Encoding functionality
bind fn CompressData(data: &c_uchar, dataLength: c_int, compDataLength: &mut c_int) &mut c_uchar;        // Compress data (DEFLATE algorithm), memory must be MemFree()
bind fn DecompressData(data: &c_uchar, dataLength: c_int, compDataLength: &mut c_int) &mut c_uchar;  // Decompress data (DEFLATE algorithm), memory must be MemFree()
bind fn EncodeDataBase64(data: &c_uchar, dataSize: c_int, outputSize: &mut c_int) &mut c_char;               // Encode data to Base64 string (includes NULL terminator), memory must be MemFree()
bind fn DecodeDataBase64(text: &c_char, outputSize: &mut c_int) &mut c_char;                             // Decode Base64 string (expected NULL terminated), memory must be MemFree()
bind fn ComputeCRC32(data: &mut c_uint, dataSize: c_int) c_uint;       // Compute CRC32 hash code
bind fn ComputeMD5(data: &mut c_uint, dataSize: c_int) &mut c_uint;        // Compute MD5 hash code, returns static int[4] (16 bytes)
bind fn ComputeSHA1(data: &mut c_uint, dataSize: c_int) &mut c_uint;       // Compute SHA1 hash code, returns static int[5] (20 bytes)
bind fn ComputeSHA256(data: &mut c_uint, dataSize: c_int) &mut c_uint;     // Compute SHA256 hash code, returns static int[8] (32 bytes)

// Automation events functionality
bind fn LoadAutomationEventList(fileName: &c_char) AutomationEventList; // Load automation events list from file, NULL for empty list, capacity = MAX_AUTOMATION_EVENTS
bind fn UnloadAutomationEventList(list: AutomationEventList) void;   // Unload automation events list from file
bind fn ExportAutomationEventList(list: AutomationEventList, fileName: &mut c_char) bool; // Export automation events list as text file
bind fn SetAutomationEventList(list: &mut AutomationEventList) void;     // Set automation event list to record to
bind fn SetAutomationEventBaseFrame(frame: c_int) void;                // Set automation event internal base frame to start recording
bind fn StartAutomationEventRecording() void;                   // Start recording automation events (AutomationEventList must be set)
bind fn StopAutomationEventRecording() void;                    // Stop recording automation events
bind fn PlayAutomationEvent(event: AutomationEvent) void;            // Play a recorded automation event

