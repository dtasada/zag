pub fn load_directory_files_ex(base_path: []u8, filter: []u8, scan_subdirs: bool) FilePathList {
    let base_path_cstr = std.to_cstr(base_path);
    defer std.free<c_char>(base_path_cstr);

    let filter_cstr = std.to_cstr(filter);
    defer std.free<c_char>(filter_cstr);

    return LoadDirectoryFilesEx(cast<&mut c_char>(base_path_cstr), cast<&mut c_char>(filter_cstr), scan_subdirs);
}
pub fn unload_directory_files(files: FilePathList) void -> UnloadDirectoryFiles(files)
pub fn is_file_dropped() bool -> IsFileDropped()
pub fn load_dropped_files() FilePathList -> LoadDroppedFiles()
pub fn unload_dropped_files(files: FilePathList) void -> UnloadDroppedFiles(files)
pub fn get_file_mod_time(file_name: []u8) i64 {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    return GetFileModTime(cast<&mut c_char>(file_name_cstr));
}
pub fn compress_data(data: []u8) []mut u8 {
    let mut slice: []mut u8 = undefined;
    slice.ptr = cast<&mut u8>(CompressData(cast<&c_uchar>(data.ptr), cast<c_int>(data.len), cast<&mut c_int>(&mut slice.len)));
    return slice;
}
pub fn decompress_data(data: []u8) []mut u8 {
    let mut slice: []mut u8 = undefined;
    slice.ptr = cast<&mut u8>(DecompressData(cast<&c_uchar>(data.ptr), cast<c_int>(data.len), cast<&mut c_int>(&mut slice.len)));
    return slice;
}
pub fn encode_data_base64(data: []u8, output_size: &mut i32) []u8 {
    let result_cstr = EncodeDataBase64(cast<&c_uchar>(data.ptr), data.len, cast<&mut c_int>(output_size));
    return cast<[]u8>(std.sentinel_to_slice<c_char>(result_cstr, 0));
}
pub fn decode_data_base64(data: []u8, output_length: &mut i32) []u8 {
    let data_cstr = std.to_cstr(data);
    defer std.free<c_char>(data_cstr);
    let result_cstr = DecodeDataBase64(cast<&mut c_char>(data_cstr), cast<&mut c_int>(output_length));
    return cast<[]u8>(std.sentinel_to_slice<c_char>(result_cstr, 0));
}
