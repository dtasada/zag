pub fn unload_wave(wave: Wave) void -> UnloadWave(wave)
pub fn unload_sound(sound: Sound) void -> UnloadSound(sound)
pub fn export_wave(wave: Wave, file_name: []u8) bool {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    return ExportWave(wave, file_name_cstr);
}
pub fn export_wave_as_code(wave: Wave, file_name: []u8) bool {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    return ExportWaveAsCode(wave, file_name_cstr);
}
pub fn play_sound(sound: Sound) void -> PlaySound(sound)
pub fn stop_sound(sound: Sound) void -> StopSound(sound)
pub fn pause_sound(sound: Sound) void -> PauseSound(sound)
pub fn resume_sound(sound: Sound) void -> ResumeSound(sound)
pub fn is_sound_playing(sound: Sound) bool -> IsSoundPlaying(sound)
pub fn set_sound_volume(sound: Sound, volume: f32) void -> SetSoundVolume(sound, volume)
pub fn set_sound_pitch(sound: Sound, pitch: f32) void -> SetSoundPitch(sound, pitch)
pub fn set_sound_pan(sound: Sound, pan: f32) void -> SetSoundPan(sound, pan)
pub fn wave_format(wave: &mut Wave, sampleRate: i32, sampleSize: i32, channels: i32) void -> WaveFormat(wave, sampleRate, sampleSize, channels)
pub fn wave_copy(wave: Wave) Wave -> WaveCopy(wave)
pub fn wave_crop(wave: &mut Wave, initSample: i32, finalSample: i32) void -> WaveCrop(wave, initSample, finalSample)
pub fn load_wave_samples(wave: Wave) &mut f32 -> cast<&mut f32>(LoadWaveSamples(wave))
pub fn unload_wave_samples(samples: &mut f32) void -> UnloadWaveSamples(cast<&mut c_float>(samples))
pub fn load_music_stream(file_name: []u8) Music {
    let file_name_cstr = std.to_cstr(file_name);
    defer std.free<c_char>(file_name_cstr);
    return LoadMusicStream(file_name_cstr);
}
pub fn load_music_stream_from_memory(file_type: []u8, data: []u8) Music {
    let file_type_cstr = std.to_cstr(file_type);
    defer std.free<c_char>(file_type_cstr);
    return LoadMusicStreamFromMemory(file_type_cstr, cast<&c_uchar>(data.ptr), cast<c_int>(data.len));
}
pub fn unload_music_stream(music: Music) void -> UnloadMusicStream(music)
pub fn play_music_stream(music: Music) void -> PlayMusicStream(music)
pub fn is_music_stream_playing(music: Music) bool -> IsMusicStreamPlaying(music)
pub fn update_music_stream(music: Music) void -> UpdateMusicStream(music)
pub fn stop_music_stream(music: Music) void -> StopMusicStream(music)
pub fn pause_music_stream(music: Music) void -> PauseMusicStream(music)
pub fn resume_music_stream(music: Music) void -> ResumeMusicStream(music)
pub fn seek_music_stream(music: Music, position: f32) void -> SeekMusicStream(music, position)
pub fn set_music_volume(music: Music, volume: f32) void -> SetMusicVolume(music, volume)
pub fn set_music_pitch(music: Music, pitch: f32) void -> SetMusicPitch(music, pitch)
pub fn set_music_pan(music: Music, pan: f32) void -> SetMusicPan(music, pan)
pub fn get_music_time_length(music: Music) f32 -> GetMusicTimeLength(music)
pub fn get_music_time_played(music: Music) f32 -> GetMusicTimePlayed(music)
pub fn load_audio_stream(sampleRate: u32, sampleSize: u32, channels: u32) AudioStream -> LoadAudioStream(sampleRate, sampleSize, channels)
pub fn unload_audio_stream(stream: AudioStream) void -> UnloadAudioStream(stream)
pub fn update_audio_stream(stream: AudioStream, data: []u8) void {
    UpdateAudioStream(stream, data.ptr, cast<c_int>(data.len));
}
pub fn is_audio_stream_processed(stream: AudioStream) bool -> IsAudioStreamProcessed(stream)
pub fn play_audio_stream(stream: AudioStream) void -> PlayAudioStream(stream)
pub fn pause_audio_stream(stream: AudioStream) void -> PauseAudioStream(stream)
pub fn resume_audio_stream(stream: AudioStream) void -> ResumeAudioStream(stream)
pub fn is_audio_stream_playing(stream: AudioStream) bool -> IsAudioStreamPlaying(stream)
pub fn stop_audio_stream(stream: AudioStream) void -> StopAudioStream(stream)
pub fn set_audio_stream_volume(stream: AudioStream, volume: f32) void -> SetAudioStreamVolume(stream, volume)
pub fn set_audio_stream_pitch(stream: AudioStream, pitch: f32) void -> SetAudioStreamPitch(stream, pitch)
pub fn set_audio_stream_pan(stream: AudioStream, pan: f32) void -> SetAudioStreamPan(stream, pan)
pub fn set_audio_stream_buffer_size_default(size: i32) void -> SetAudioStreamBufferSizeDefault(size)
pub fn set_audio_stream_callback(stream: AudioStream, callback: AudioCallback) void -> SetAudioStreamCallback(stream, callback)
pub fn attach_audio_stream_processor(stream: AudioStream, processor: AudioCallback) void -> AttachAudioStreamProcessor(stream, processor)
pub fn detach_audio_stream_processor(stream: AudioStream, processor: AudioCallback) void -> DetachAudioStreamProcessor(stream, processor)

