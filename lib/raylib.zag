pub fn init_window(width, height: i32, title: []u8) void {
    let title_cstr = std.to_cstr(title);
    defer std.free<c_char>(title_cstr);
    InitWindow(width, height, cast<&mut c_char>(title_cstr));
} 
pub fn close_window() void -> CloseWindow()
pub fn window_should_close() bool -> WindowShouldClose()
