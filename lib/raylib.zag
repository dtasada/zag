pub fn is_window_focused() bool -> IsWindowFocused()
pub fn is_window_resized() bool -> IsWindowResized()
pub fn is_window_state(flags: []ConfigFlags) bool {
    let mut flag_int = 0;
    for (flags) |f| flag_int |= cast<i32>(f);
    return IsWindowState(flag_int);
}
pub fn set_window_state(flags: []ConfigFlags) void {
    let mut flag_int = 0;
    for (flags) |f| flag_int |= cast<i32>(f);
    SetWindowState(flag_int);
}
pub fn clear_window_state(flags: []ConfigFlags) void {
    let mut flag_int = 0;
    for (flags) |f| flag_int |= cast<i32>(f);
    ClearWindowState(flag_int);
}
