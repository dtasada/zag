    let text_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_cstr);
    return GetCodepoint(cast<&mut c_char>(text_cstr), cast<&mut c_int>(bytesProcessed));
} 
pub fn codepoint_to_utf8(codepoint: i32) []u8 {
    let mut slice: []u8 = undefined;
    slice.ptr = cast<&u8>(CodepointToUTF8(codepoint, cast<&mut c_int>(&mut slice.ptr)));
    return slice;
}
pub fn text_copy(dst: &mut c_char, src: &c_char) i32 -> TextCopy(dst, src)
pub fn text_is_equal(text1: []u8, text2: []u8) bool {
    let text1_cstr = std.to_cstr(text1);
    defer std.free<c_char>(text1_cstr);
    let text2_cstr = std.to_cstr(text2);
    defer std.free<c_char>(text2_cstr);
    return TextIsEqual(text1_cstr, text2_cstr);
}
pub fn text_length(text: []u8) u32 {
    return cast<u32>(text.len);
}
// pub fn text_format(text: &c_char, args...) &c_char -> TextFormat(text, args...)
pub fn text_subtext(text: []u8, position: i32, length: i32) []u8 {
    return text[cast<usize>(position)..cast<usize>(position + length)];
}
pub fn text_replace(text: []u8, replace: []u8, by: []u8) []u8 {
    let text_copy_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_copy_cstr);
    
    let replace_cstr = std.to_cstr(replace);
    defer std.free<c_char>(replace_cstr);

    let by_cstr = std.to_cstr(by);
    defer std.free<c_char>(by_cstr);

    let result_cstr = TextReplace(cast<&mut c_uchar>(text_copy_cstr), replace_cstr, by_cstr);
    defer std.free<u8>(cast<&mut u8>(result_cstr));
    
    return cast<[]u8>(std.sentinel_to_slice<c_char>(result_cstr, 0));
}
pub fn text_insert(text: []u8, insert: []u8, position: i32) []u8 {
    let text_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_cstr);
    
    let insert_cstr = std.to_cstr(insert);
    defer std.free<c_char>(insert_cstr);

    let result_cstr = TextInsert(text_cstr, insert_cstr, cast<c_int>(position));
    defer std.free<u8>(cast<&mut u8>(result_cstr));

    return cast<[]u8>(std.sentinel_to_slice<c_char>(result_cstr, 0));
}
pub fn text_join(texts: [][]u8, joiner: []u8) []u8 {
    if (texts.len == 0) {
        return "";
    }

    let mut total_len: usize = 0;
    let mut i: usize = 0;
    while (i < texts.len) {
        total_len += texts[i].len;
        i += 1;
    }
    total_len += (texts.len - 1) * joiner.len;

    let new_slice = std.alloc_slice<u8>(total_len);
    let mut current_pos: usize = 0;

    i = 0;
    while (i < texts.len) {
        let s = texts[i];
        std.memcpy_slice<u8>(new_slice[current_pos..current_pos + s.len], s);
        current_pos += s.len;
        if (i < texts.len - 1) {
            std.memcpy_slice<u8>(new_slice[current_pos..current_pos + joiner.len], joiner);
            current_pos += joiner.len;
        }
        i += 1;
    }
    return new_slice;
}
pub fn text_split(text: []u8, delimiter: u8) [][]u8 {
    let mut list = std.ArrayList<[]u8>.init();
    defer list.deinit();

    let mut start: usize = 0;
    let mut i: usize = 0;
    while (i < text.len) {
        if (text[i] == delimiter) {
            list.append(text[start..i]);
            start = i + 1;
        }
        i += 1;
    }
    list.append(text[start..text.len]);
    
    let result = std.alloc_slice<[]u8>(list.items.len);
    std.memcpy_slice<[]u8>(result, list.items);
    return result;
}
pub fn text_append(text: []u8, to_append: []u8) []u8 {
    let new_len = text.len + to_append.len;
    let new_slice = std.alloc_slice<u8>(new_len);
    std.memcpy_slice<u8>(new_slice[0..text.len], text);
    std.memcpy_slice<u8>(new_slice[text.len..new_len], to_append);
    return new_slice;
}
pub fn text_find_index(text: []u8, find: []u8) i32 {
    let text_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_cstr);
    let find_cstr = std.to_cstr(find);
    defer std.free<c_char>(find_cstr);
    return TextFindIndex(text_cstr, find_cstr);
}
