pub fn load_codepoints(text: []u8) []mut i32 {
    let text_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_cstr);

    let mut c_count: c_int = 0;
    let mut slice: []mut i32 = undefined;
    slice.ptr = cast<&mut i32>(LoadCodepoints(text_cstr, cast<&mut c_int>(&mut c_count)));
    slice.len = cast<usize>(c_count);
    return slice;
}
pub fn unload_codepoints(codepoints: []mut i32) void -> UnloadCodepoints(cast<&mut c_int>(codepoints.ptr))
pub fn get_codepoint_count(text: []u8) i32 {
    let text_cstr = std.to_cstr(text);
    defer std.free<c_char>(text_cstr);
    return GetCodepointCount(cast<&mut c_char>(text_cstr));
}
