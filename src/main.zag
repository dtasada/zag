bind fn printf(fmt: &c_char, args...) c_int;

let some_global: i32 = 42;

struct Vector2 {
    x, y: f32,

    fn init(x, y: f32) Vector2 -> Vector2 { x: x, y: y }
}

fn main() void {
    let sixnine = 69;
    printf("hello world %d, %d\n", some_global, sixnine);
    defer printf("hello again\n");

    let v2 = Vector2 { x: 1, y: 2 };

    return 0;
}
