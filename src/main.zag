import lib;

struct MyStruct {
    x, y: i32,
    z: f32
}

union MyUnion {
    f: f32,
    i: i32,
    c: u8,

    fn print(self: MyUnion) void {
        lib.printf("self: %c", self.c);
    }
}

fn print_num<N: i32>() void {
    lib.printf("N is %d\n", N);
}

fn id<T>(val: T) T {
    return val;
}

fn main() i32 {
    let mu = MyUnion { i: 65 };

    let ms = lib.alloc<MyStruct>();

    mu.print();

    print_num<42>();

    let x: i32 = id<i32>(10);
    lib.printf("x: %d\n", x);
}
